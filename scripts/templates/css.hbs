:root {
  --icon-action: #702C62;
  --icon-hover: #542149;
  --icon-success: #339900;
  --icon-warning: #FF7C00;
  --icon-error: #E54141;
  --icon-text: #212121;
  --icon-disabled: #9E9E9E;
  --icon-on-disabled: #757575;
  --icon-on-action: #FFFFFF;
  --icon-bg-hover: #DBCAD8;
}

@font-face {
    font-family: "{{ name }}";
    src: {{{ fontSrc }}};
}

.icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    width: 1em;
    height: 1em;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-style: normal;
    font-variant: normal;
    font-weight: normal;
    text-transform: none;
    vertical-align: middle;
}

/* Size Utilities */
.icon-8  { font-size: 8px !important; }
.icon-10 { font-size: 10px !important; }
.icon-sm { font-size: 12px !important; }
.icon-14 { font-size: 14px !important; }
.icon-lg { font-size: 20px !important; }
.icon-xl { font-size: 24px !important; }

/* Color Utilities */
.icon-primary { color: var(--icon-action); }
.icon-success { color: var(--icon-success); }
.icon-warning { color: var(--icon-warning); }
.icon-error   { color: var(--icon-error); }
.icon-on-action { color: var(--icon-on-action); }
.icon-muted   { color: var(--icon-disabled); }

/* State Utilities */
.icon-state-hover {
    background: var(--icon-bg-hover);
    color: var(--icon-action);
    border-radius: 2px;
    padding: 2px;
}

.icon-state-selected {
    background: var(--icon-action);
    color: var(--icon-on-action);
    border-radius: 2px;
    padding: 2px;
}

.icon-state-disabled {
    background: #D3D3D3;
    color: var(--icon-on-disabled);
    border-radius: 2px;
    padding: 2px;
}

{{# each codepoints }}
.{{ @key }}:before {
    font-family: "{{ ../name }}" !important;
    content: "\\{{ this }}";
}
{{/ each }}

